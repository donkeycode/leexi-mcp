# Leexi public API credentials (key id + secret pair)
# Generate at: Leexi → Settings → Company Settings → API Keys (admin required)
# The API uses HTTP Basic Auth: Authorization: Basic base64(KEY_ID:KEY_SECRET)
LEEXI_API_KEY_ID=your-key-id-here
LEEXI_API_KEY=your-key-secret-here
LEEXI_API_BASE_URL=https://public-api.leexi.ai/v1

# Local state file (processed call UUIDs)
LEEXI_STATE_FILE=./state/processed-calls.json

# Optional: rate limit override (default 50/min from Leexi)
LEEXI_RATE_LIMIT_PER_MINUTE=50
