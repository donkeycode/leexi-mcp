# Allow these packages to run their install scripts (esbuild needs it for
# native binaries, msw for service worker, biome for native CLI binary).
only-built-dependencies[]=@biomejs/biome
only-built-dependencies[]=esbuild
only-built-dependencies[]=msw

# Disable the supply-chain "minimum release age" policy (rejects pkgs
# published <12h ago by default). Set to 0 for fast iteration; tighten later.
minimum-release-age=0
