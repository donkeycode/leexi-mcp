{
  "name": "@donkeycode/leexi-mcp",
  "version": "0.1.0",
  "description": "DonkeyCode MCP server for Leexi (AI Notetaker) — exposes calls, transcripts, and processing state.",
  "license": "MIT",
  "author": "DonkeyCode <hello@donkeycode.com>",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "leexi-mcp": "dist/index.js"
  },
  "files": ["dist", "README.md", "LICENSE"],
  "engines": { "node": ">=20" },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check src tests",
    "format": "biome format --write src tests",
    "inspect": "tsx scripts/inspect.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "undici": "^6.19.0",
    "zod": "^3.23.0",
    "zod-to-json-schema": "^3.23.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.8.0",
    "@types/node": "^20.14.0",
    "msw": "^2.3.0",
    "tsx": "^4.15.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["@biomejs/biome", "esbuild", "msw"]
  }
}
